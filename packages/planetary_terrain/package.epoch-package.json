{
  "id": "planetary_terrain",
  "displayName": "Planetary Terrain Extension",
  "manifestLicense": "LicenseRef-MIT-NoSell",
  "manifestCopyright": "Copyright (c) 2026 Adam Rushford",
  "status": "source-staged",
  "kind": "code-extension",
  "activation": "package-manager-opt-in",
  "summary": "NMS-like planetary terrain and multi-terrain stacks kept outside minimal EpochEngine clones.",
  "security": {
    "serverOrListenerAllowed": false,
    "requiresExplicitNetworkApproval": false,
    "autoRunAllowed": false,
    "includeByDefault": false
  },
  "source": {
    "repo": "https://github.com/Autodidac/EpochEngineExtensions",
    "path": "packages/planetary_terrain",
    "provenance": "renderer-neutral C++23 planetary terrain composition source staged in this package"
  },
  "engineBoundary": {
    "epochPackageId": "planetary_terrain",
    "expectedCacheRoot": "cache/packages/planetary_terrain",
    "notes": "Use core voxel field/pathing/tracing contracts, but keep heavy generation and authoring code package-gated."
  },
  "script": {
    "language": "C++23",
    "path": "scripts/planetary_terrain_package.ascript.cpp",
    "api": "epoch_package_script_api",
    "mode": "download-stage-build-live-preview",
    "downloadsSource": true,
    "compilesSource": true,
    "livePreview": true,
    "humanGated": true,
    "autoRunAllowed": false
  },
  "build": {
    "humanGated": true,
    "sourceFiles": [
      "CMakeLists.txt",
      "include/epoch/extensions/planetary_terrain/planetary_terrain.hpp",
      "src/planetary_terrain.cpp",
      "tests/planetary_terrain_self_test.cpp"
    ],
    "targets": [
      "epoch_extension_planetary_terrain",
      "epoch_extension_planetary_terrain_self_test"
    ],
    "commands": [
      "cmake -S packages/planetary_terrain -B cache/packages/planetary_terrain/build",
      "cmake --build cache/packages/planetary_terrain/build --target epoch_extension_planetary_terrain_self_test",
      "cache/packages/planetary_terrain/build/epoch_extension_planetary_terrain_self_test"
    ]
  },
  "notes": [
    "Stages terrain samples, biome classification, and tile neighborhood planning above core voxel/trace contracts."
  ]
}
