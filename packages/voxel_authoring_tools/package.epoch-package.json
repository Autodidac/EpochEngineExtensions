{
  "id": "voxel_authoring_tools",
  "displayName": "Voxel Authoring Tools",
  "manifestLicense": "LicenseRef-MIT-NoSell",
  "manifestCopyright": "Copyright (c) 2026 Adam Rushford",
  "status": "source-staged",
  "kind": "code-extension",
  "activation": "package-manager-opt-in",
  "summary": "Voxel authoring/toolkit code extension staged for API-boundary review.",
  "security": {
    "serverOrListenerAllowed": false,
    "requiresExplicitNetworkApproval": false,
    "autoRunAllowed": false,
    "includeByDefault": false
  },
  "source": {
    "repo": "https://github.com/Autodidac/EpochEngineExtensions",
    "path": "packages/voxel_authoring_tools",
    "provenance": "renderer-neutral C++23 sparse voxel authoring source staged in this package"
  },
  "engineBoundary": {
    "epochPackageId": "voxel_authoring_tools",
    "expectedCacheRoot": "cache/packages/voxel_authoring_tools",
    "notes": "Review for voxel authoring concepts that map onto EpochEngine voxel.field and voxel.trace contracts."
  },
  "script": {
    "language": "C++23",
    "path": "scripts/voxel_authoring_tools_package.ascript.cpp",
    "api": "epoch_package_script_api",
    "mode": "download-stage-build-live-preview",
    "downloadsSource": true,
    "compilesSource": true,
    "livePreview": true,
    "humanGated": true,
    "autoRunAllowed": false
  },
  "build": {
    "humanGated": true,
    "sourceFiles": [
      "CMakeLists.txt",
      "include/epoch/extensions/voxel_authoring_tools/voxel_authoring_tools.hpp",
      "src/voxel_authoring_tools.cpp",
      "tests/voxel_authoring_tools_self_test.cpp"
    ],
    "targets": [
      "epoch_extension_voxel_authoring_tools",
      "epoch_extension_voxel_authoring_tools_self_test"
    ],
    "commands": [
      "cmake -S packages/voxel_authoring_tools -B cache/packages/voxel_authoring_tools/build",
      "cmake --build cache/packages/voxel_authoring_tools/build --target epoch_extension_voxel_authoring_tools_self_test",
      "cache/packages/voxel_authoring_tools/build/epoch_extension_voxel_authoring_tools_self_test"
    ]
  },
  "notes": [
    "Stages sparse density editing, sphere brush replay, material stamping, and deterministic editor evidence without renderer handles."
  ]
}
