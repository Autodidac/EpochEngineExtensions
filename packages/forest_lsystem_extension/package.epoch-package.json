{
  "id": "forest_lsystem_extension",
  "displayName": "Forest L-System Extension",
  "manifestLicense": "LicenseRef-MIT-NoSell",
  "manifestCopyright": "Copyright (c) 2026 Adam Rushford",
  "status": "source-staged",
  "kind": "code-extension",
  "activation": "package-manager-opt-in",
  "summary": "Optional Forest Factory reference/code extension for reviewed L-system material.",
  "security": {
    "serverOrListenerAllowed": false,
    "requiresExplicitNetworkApproval": false,
    "autoRunAllowed": false,
    "includeByDefault": false
  },
  "source": {
    "repo": "https://github.com/Autodidac/EpochEngineExtensions",
    "path": "packages/forest_lsystem_extension",
    "upstreamReference": "https://github.com/Autodidac/WickedTwoOLSystem@482b84768447247b076fd4322cba82b285b32698",
    "provenance": "renderer-neutral C++23 Forest Factory L-system source staged in this package"
  },
  "engineBoundary": {
    "epochPackageId": "forest_lsystem_extension",
    "expectedCacheRoot": "cache/packages/forest_lsystem_extension",
    "notes": "Forest Factory is core in EpochEngine; this package is optional extension/reference material."
  },
  "script": {
    "language": "C++23",
    "path": "scripts/forest_lsystem_extension_package.ascript.cpp",
    "api": "epoch_package_script_api",
    "mode": "download-stage-build-live-preview",
    "downloadsSource": true,
    "compilesSource": true,
    "livePreview": true,
    "humanGated": true,
    "autoRunAllowed": false
  },
  "build": {
    "humanGated": true,
    "sourceFiles": [
      "CMakeLists.txt",
      "include/epoch/extensions/forest_lsystem_extension/forest_lsystem.hpp",
      "src/forest_lsystem.cpp",
      "tests/forest_lsystem_self_test.cpp"
    ],
    "targets": [
      "epoch_extension_forest_lsystem",
      "epoch_extension_forest_lsystem_self_test"
    ],
    "commands": [
      "cmake -S packages/forest_lsystem_extension -B cache/packages/forest_lsystem_extension/build",
      "cmake --build cache/packages/forest_lsystem_extension/build --target epoch_extension_forest_lsystem_self_test",
      "cache/packages/forest_lsystem_extension/build/epoch_extension_forest_lsystem_self_test"
    ]
  },
  "notes": [
    "Stages deterministic grammar expansion and branch segment generation for future Forest Factory, voxel occupancy, and renderer adapter outputs."
  ]
}
